import requests import pandas as pd

url = "https://jsonplaceholder.typicode.com/users" response = requests.get(url) data = response.json()

print("Fetched Records:", len(data))

=========================

2. LOAD INTO PANDAS

=========================

df = pd.DataFrame(data) print("\nInitial DataFrame:") print(df.head())

=========================

3. DATA CLEANING

=========================

Handle missing values

print("\nMissing Values:") print(df.isnull().sum())

Example: Fill missing (if any)

df.fillna("Unknown", inplace=True)

=========================

4. DATA TRANSFORMATION

=========================

Extract nested data (address -> city)

df['city'] = df['address'].apply(lambda x: x['city'])

Extract company name

df['company_name'] = df['company'].apply(lambda x: x['name'])

Drop unnecessary columns

df.drop(['address', 'company'], axis=1, inplace=True)

print("\nTransformed DataFrame:") print(df.head())

=========================

5. DATA ANALYSIS

=========================

print("\nUnique Cities:", df['city'].nunique()) print("Users per City:") print(df['city'].value_counts())

=========================

6. SAVE DATA

=========================

df.to_csv("users_cleaned.csv", index=False) df.to_excel("users_cleaned.xlsx", index=False)

print("\nData saved to CSV and Excel.")

=========================

7. AUTOMATION PIPELINE

=========================

def api_to_pipeline(api_url): try: res = requests.get(api_url) res.raise_for_status() data = res.json()

df = pd.DataFrame(data)

    # Cleaning
    df.fillna("Unknown", inplace=True)

    # Example transformation
    if 'address' in df.columns:
        df['city'] = df['address'].apply(lambda x: x.get('city', 'Unknown'))

    # Save file
    df.to_csv("pipeline_output.csv", index=False)

    print("Pipeline executed successfully!")

except Exception as e:
    print("Pipeline Error:", e)

Run pipeline

api_to_pipeline("https://jsonplaceholder.typicode.com/users")

