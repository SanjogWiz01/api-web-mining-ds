FILE 5: advanced_requests.py

=========================

import requests

File Upload

files = {'file': open('test.txt', 'rb')} response = requests.post("https://httpbin.org/post", files=files) print("File Upload:", response.status_code)

Streaming response

response = requests.get("https://httpbin.org/stream/20", stream=True) for line in response.iter_lines(): if line: print(line)

Error handling

try: response = requests.get("https://httpbin.org/status/404") response.raise_for_status() except requests.exceptions.HTTPError as e: print("HTTP Error:", e)

Custom exception handling

try: requests.get("invalid_url") except requests.exceptions.RequestException as e: print("General Error:", e)

SSL Verification

response = requests.get("https://httpbin.org/get", verify=True) print("SSL Verified:", response.status_code)