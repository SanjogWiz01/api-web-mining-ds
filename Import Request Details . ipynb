import requests

session = requests.Session()

Persist headers

session.headers.update({"User-Agent": "SessionApp"})

Cookies handling

response = session.get("https://httpbin.org/cookies/set/sessioncookie/123456") print("Cookies:", session.cookies.get_dict())

Timeout

try: response = requests.get("https://httpbin.org/delay/3", timeout=2) except requests.exceptions.Timeout: print("Request timed out")

